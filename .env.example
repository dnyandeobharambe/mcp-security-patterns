# Copy this to .env and fill in your values
# Never commit .env to git

# Azure Key Vault (Pattern MCP01)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# Local dev mock (use this instead of real Key Vault for testing)
USE_MOCK_KEY_VAULT=true
MOCK_API_KEY=mock-api-key-never-use-in-production

# LangSmith (Pattern MCP08)
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=mcp-security-patterns

# AgentOps (Pattern MCP08)
AGENTOPS_API_KEY=your-agentops-key

# HITL Webhook (Pattern MCP02)
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-webhook
HITL_APPROVAL_TIMEOUT_SECONDS=300

# OAuth (Pattern MCP07)
OAUTH_ISSUER=https://your-auth-server.com
OAUTH_AUDIENCE=mcp-server
OAUTH_JWKS_URI=https://your-auth-server.com/.well-known/jwks.json

# AI Models
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_API_KEY=your-gemini-key

# Triage Gate (Pattern MCP05/06)
USE_MOCK_TRIAGE_GATE=true
GEMINI_API_KEY=your-gemini-key

# Redis (Pattern MCP10)
REDIS_URL=redis://localhost:6379
